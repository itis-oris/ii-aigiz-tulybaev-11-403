        "react": "19.2.4",
        "react-dom": "19.2.4",
        "shadcn": "^4.1.2",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
