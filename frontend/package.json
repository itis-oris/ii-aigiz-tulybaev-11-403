{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:mock": "API_PROXY_TARGET=http://127.0.0.1:4010 next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "stylelint": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
        "lint-staged": "lint-staged",
        "prepare": "test -d ../.git && (cd .. && ./frontend/node_modules/.bin/husky frontend/.husky) || true",
        "steiger": "npx steiger .",
        "steiger:fix": "npx steiger . --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@dnd-kit/react": "^0.4.0",
        "@hugeicons/core-free-icons": "^4.1.1",
        "@hugeicons/react": "^1.1.6",
        "@tanstack/react-query": "^5.96.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "next": "16.2.3",
        "radix-ui": "^1.4.3",
        "react": "19.2.4",
        "react-day-picker": "^10.0.0",
        "react-dom": "19.2.4",
        "shadcn": "^4.2.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.2",
        "@feature-sliced/steiger-plugin": "^0.5.7",
        "@stoplight/prism-cli": "^5.14.2",
        "@storybook/addon-a11y": "^10.3.6",
        "@storybook/addon-docs": "^10.3.6",
        "@storybook/addon-onboarding": "^10.3.6",
        "@storybook/addon-vitest": "^10.3.6",
        "@storybook/nextjs-vite": "^10.3.6",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/browser-playwright": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^9",
        "eslint-config-next": "16.2.2",
        "eslint-plugin-storybook": "^10.3.6",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.1",
        "playwright": "^1.59.1",
        "prettier": "^3.6.2",
        "steiger": "^0.5.11",
        "storybook": "^10.3.6",
        "stylelint": "^16.24.0",
        "stylelint-config-standard": "^39.0.1",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vite": "^8.0.11",
        "vitest": "^4.1.5"
